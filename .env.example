# ────────────────────────────────────────────────
# Eventyr Sailing Logistics — Environment Variables
# Copy this file to .env.local and fill in values
# ────────────────────────────────────────────────

# App URL (used in Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=https://www.eventyrsailinglogistics.com

# Supabase — use the SAME project as eventyrperformance
# (shared auth so users are recognised on both sites)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe — same Stripe account, but register a NEW webhook endpoint
# pointing to https://www.eventyrsailinglogistics.com/api/stripe/webhook
# to get a fresh STRIPE_WEBHOOK_SECRET for this domain
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SHIPPING_EU_STANDARD=shr_...

# Email (Nodemailer) — for RIB booking confirmations and reminders
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@eventyrsailinglogistics.com

# Dev gate (set to false in production once site is launched)
ENABLE_DEV_GATE=false
DEV_GATE_USERNAME=admin
DEV_GATE_PASSWORD=changeme
